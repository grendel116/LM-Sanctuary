# Python env and cache
.venv/
__pycache__/
*.pyc

# Local Config (contains credentials)
.env

# Temporary files
backups/
scratch/*
!scratch/news_deep_research.py
reports/

# Ignore all runtime and user variables except code dependencies, template examples, and default builder profile
variables/*
!variables/__init__.py
!variables/user.md.example
!variables/user_profiles/
!variables/banned_words.json
variables/user_profiles/*
!variables/user_profiles/builder.md

# Ignore all companion profiles under core/programs except the default Arthur program template
core/programs/*
!core/programs/arthur/
!core/programs/sebile/
!core/programs/sparkle.mp3

# Ignore user-generated dynamic program sessions, databases, and custom generated portraits
core/programs/*/sessions/
core/programs/*/portraits/
core/programs/*/media/
core/programs/*/uploads/
core/programs/*/databank.db
core/embeddings.pkl
temp_uploads/

# TTS Speech Model weights and synthesized audio cache
core/skills/speech_generation/speech_model/*.onnx
core/skills/speech_generation/speech_model/*.bin
core/skills/speech_generation/speech_cache/

# Runtime logs
*.log