# Sanctuary Environment Configurations

# Active language model engine backend: 'google_adk' (Gemini ADK) or 'opensource' (scaffolding)
# Toggle between 'google_adk' for cloud-hosted Gemini and 'opensource' for fully offline local servers.
RUNNER_BACKEND=opensource

# --- SERVER HOST & PORT CONFIGURATION ---
# The IP address the main server should bind to. Use '0.0.0.0' to listen on all interfaces.
# If you are using Tailscale and having connection issues, you can explicitly set this to your Tailscale IP (e.g., 100.x.y.z).
HOST=0.0.0.0
PORT=5000

# --- REMOTE BACKEND SETUP ---
# Required for remote cloud offloading (OpenRouter, DeepSeek, OpenAI, Gemini OpenAI-endpoint, etc.)
REMOTE_API_KEY=your_remote_api_key_here
REMOTE_CLOUD_URL=https://api.openai.com/v1/chat/completions
REMOTE_MODEL=gemini-2.5-flash

# --- OPEN-SOURCE & COOPERATIVE REMOTE BACKEND SETUP (Local LLM / Coop Runner / Ollama) ---
# Used if RUNNER_BACKEND=opensource OR when using 'local-llm' model in ADK runner
# Note: You can point REMOTE_SERVER_URL to a remote cooperative compute cluster, OpenRouter, or OpenAI
REMOTE_SERVER_URL=http://localhost:1234/v1/chat/completions
LOCAL_MODEL_NAME=meta-llama-3-8b-instruct

# Local LLM Context:
# LOCAL_CONTEXT: Override default model context length (optional, e.g. 4096).
# LOCAL_CONTEXT=4096

# --- IMAGE GENERATION SETUP (ComfyUI) ---
# Active URL of your local ComfyUI server
COMFYUI_SERVER_URL=http://127.0.0.1:8188
# Local directory path of ComfyUI installation. Fallback is relative to workspace (../ComfyUI)
COMFYUI_DIR=
# Configurable SDXL/Illustrious checkpoint filename (placed in ComfyUI/models/checkpoints/)
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
# Configurable SDXL VAE filename (placed in ComfyUI/models/vae/)
COMFYUI_VAE=sdxl_vae.safetensors
# Active ComfyUI workflow JSON template path for portrait animation
COMFYUI_VIDEO_WORKFLOW=core/skills/portrait_generation/VideoWorkflow.json
# Active ComfyUI workflow JSON template path for portrait generation
COMFYUI_IMAGE_WORKFLOW=core/skills/portrait_generation/ImageWorkflow.json

# Extra command line arguments for ComfyUI server (e.g., --lowvram or --disable-smart-memory)
COMFYUI_ARGS=--lowvram

# --- SECURITY & AUTHENTICATION SETUP (Wi-Fi phone syncing) ---
# Optional: Define a username and password to secure connection when syncing over local Wi-Fi.
# Leave blank to run without credentials on local networks.
AUTH_USER=
AUTH_PASS=

# --- HTTPS / SSL CONFIGURATION ---
# Set to true to enable self-signed (ad-hoc) HTTPS. Requires 'pyopenssl' package: pip install pyopenssl
USE_HTTPS=false
# To use clean custom SSL certificates (e.g. from tailscale cert):
# SSL_CERT=your_cert.crt
# SSL_KEY=your_key.key

# --- CIVITAI CLOUD GENERATION API SETUP ---
# Generate your API key in your Civitai Account Settings
CIVITAI_API_TOKEN=your_civitai_api_token_here
